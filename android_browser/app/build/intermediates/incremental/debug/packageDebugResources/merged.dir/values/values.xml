<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:ns1="http://schemas.android.com/tools">
    <color name="black">#000000</color>
    <color name="colorAccent">#FF9800</color>
    <color name="colorPrimary">#2196F3</color>
    <color name="colorPrimaryDark">#1976D2</color>
    <color name="gray_light">#F5F5F5</color>
    <color name="gray_medium">#757575</color>
    <color name="white">#FFFFFF</color>
    <string name="app_name">Simple Browser</string>
    <string name="back">Back</string>
    <string name="forward">Forward</string>
    <string name="home">Home</string>
    <string name="refresh">Refresh</string>
    <string name="url_hint">Enter URL or search...</string>
    <style name="Theme.SimpleBrowser" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor" ns1:targetApi="l">?attr/colorPrimaryVariant</item>
    </style>
    <style name="Theme.SimpleBrowser.Dark" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#424242</item>
        <item name="colorPrimaryVariant">#212121</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#FF9800</item>
        <item name="colorSecondaryVariant">#F57C00</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor" ns1:targetApi="l">?attr/colorPrimaryVariant</item>
    </style>
