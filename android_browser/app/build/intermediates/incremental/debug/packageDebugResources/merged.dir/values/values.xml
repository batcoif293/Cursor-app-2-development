    </style>
    <style name="Theme.SimpleBrowser.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="Theme.SimpleBrowser.Orange" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
